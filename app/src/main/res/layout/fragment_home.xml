<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/homeRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0D0D14">

    <!-- Header mirrors radio/sounds page style -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingLeft="16dp"
        android:paddingRight="16dp"
        android:paddingTop="20dp"
        android:paddingBottom="12dp">

        <ImageView
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/ic_note"
            android:scaleType="fitCenter"
            android:alpha="0.65"
            android:layout_gravity="center_horizontal"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Home"
            android:textColor="#FFFFFF"
            android:textSize="26sp"
            android:fontFamily="sans-serif-medium"
            android:paddingTop="8dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Your ambient space"
            android:textColor="#8888AA"
            android:textSize="13sp"
            android:paddingTop="2dp"/>

    </LinearLayout>

    <View android:id="@+id/settingsDivider2"
        android:layout_width="match_parent" android:layout_height="1dp"
        android:background="#22223A"/>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:overScrollMode="never">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingLeft="16dp"
            android:paddingRight="16dp"
            android:paddingBottom="24dp">

            <!-- ── NOW PLAYING section ── -->
            <TextView
                android:id="@+id/tvNowPlayingLabel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="NOW PLAYING"
                android:textColor="#FFFFFF"
                android:textSize="11sp"
                android:letterSpacing="0.1"
                android:fontFamily="sans-serif-medium"
                android:paddingTop="20dp"
                android:paddingBottom="10dp"
                android:visibility="gone"/>

            <!-- Radio now-playing card (squircle icon + name) -->
            <LinearLayout
                android:id="@+id/nowPlayingRadioCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="14dp"
                android:layout_marginBottom="10dp"
                android:clickable="true"
                android:focusable="true"
                android:visibility="gone">

                <!-- Squircle station icon -->
                <ImageView
                    android:id="@+id/ivStationIcon"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:src="@drawable/ic_note"
                    android:scaleType="centerCrop"
                    android:layout_marginRight="14dp"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Radio"
                        android:textColor="#8888AA"
                        android:textSize="11sp"/>

                    <TextView
                        android:id="@+id/tvNowPlayingStation"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Station name"
                        android:textColor="#FFFFFF"
                        android:textSize="15sp"
                        android:fontFamily="sans-serif-medium"
                        android:singleLine="true"
                        android:ellipsize="end"/>

                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="✕"
                    android:textColor="#8888AA"
                    android:textSize="16sp"
                    android:paddingLeft="10dp"/>

            </LinearLayout>

            <!-- Active sounds row (chips) -->
            <LinearLayout
                android:id="@+id/nowPlayingSoundsContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:flexDirection="row"
                android:flexWrap="wrap"
                android:layout_marginBottom="4dp"/>

            <View
                android:id="@+id/dividerNowPlaying"
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#22223A"
                android:layout_marginTop="8dp"
                android:visibility="gone"/>

            <!-- ── FAVOURITES section ── -->
            <TextView
                android:id="@+id/tvFavRadioLabel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="FAVOURITE RADIO"
                android:textColor="#FFFFFF"
                android:textSize="11sp"
                android:letterSpacing="0.1"
                android:fontFamily="sans-serif-medium"
                android:paddingTop="20dp"
                android:paddingBottom="10dp"
                android:visibility="gone"/>

            <!-- Favourite radio chips (wrap) -->
            <LinearLayout
                android:id="@+id/favRadioContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="4dp"/>

            <TextView
                android:id="@+id/tvFavSoundsLabel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="FAVOURITE SOUNDS"
                android:textColor="#FFFFFF"
                android:textSize="11sp"
                android:letterSpacing="0.1"
                android:fontFamily="sans-serif-medium"
                android:paddingTop="16dp"
                android:paddingBottom="10dp"
                android:visibility="gone"/>

            <!-- Favourite sounds chips -->
            <LinearLayout
                android:id="@+id/favSoundsContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="4dp"/>

            <View
                android:id="@+id/dividerFav"
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#22223A"
                android:layout_marginTop="8dp"
                android:visibility="gone"/>

            <!-- Empty state -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Nothing playing yet.\n\nTap a radio station or a sound button to get started.\n\nDouble-tap any station or sound to add it to Favourites here."
                android:textColor="#44445A"
                android:textSize="13sp"
                android:lineSpacingExtra="4dp"
                android:paddingTop="40dp"
                android:gravity="center"/>

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

</LinearLayout>