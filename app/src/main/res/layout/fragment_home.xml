<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/homeRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0D0D14">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingLeft="16dp" android:paddingRight="16dp"
        android:paddingTop="20dp"  android:paddingBottom="12dp">

        <TextView
            android:id="@+id/tvHomePageTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Home"
            android:textColor="#FFFFFF"
            android:textSize="26sp"
            android:fontFamily="sans-serif-medium"/>

        <TextView
            android:id="@+id/tvHomePageSubtitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Your ambient space"
            android:textColor="#8888AA"
            android:textSize="13sp"
            android:paddingTop="2dp"/>

    </LinearLayout>

    <View android:layout_width="match_parent" android:layout_height="1dp"
        android:background="#22223A"/>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:overScrollMode="never">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingLeft="16dp" android:paddingRight="16dp"
            android:paddingBottom="24dp">

            <!-- NOW PLAYING label -->
            <TextView
                android:id="@+id/tvNowPlayingLabel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="NOW PLAYING"
                android:textColor="#FFFFFF" android:textSize="11sp"
                android:letterSpacing="0.1" android:fontFamily="sans-serif-medium"
                android:paddingTop="20dp" android:paddingBottom="10dp"
                android:visibility="gone"/>

            <!-- Radio now-playing card -->
            <FrameLayout
                android:id="@+id/nowPlayingRadioCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="10dp"
                android:elevation="8dp"
                android:clickable="true" android:focusable="true"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingLeft="14dp" android:paddingRight="10dp"
                        android:paddingTop="14dp" android:paddingBottom="8dp">

                        <ImageView
                            android:id="@+id/ivStationIcon"
                            android:layout_width="40dp" android:layout_height="40dp"
                            android:src="@drawable/ic_note_vec"
                            android:scaleType="centerCrop"
                            android:layout_marginEnd="12dp"/>

                        <LinearLayout
                            android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:orientation="vertical">

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Radio" android:textColor="#8888AA"
                                android:textSize="11sp"/>

                            <TextView
                                android:id="@+id/tvNowPlayingStation"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:textColor="#FFFFFF" android:textSize="15sp"
                                android:fontFamily="sans-serif-medium"
                                android:singleLine="true" android:ellipsize="end"/>

                            <TextView
                                android:id="@+id/tvBuffering"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Buffering…" android:textColor="#6C63FF"
                                android:textSize="11sp" android:paddingTop="1dp"
                                android:visibility="gone"/>

                        </LinearLayout>

                        <TextView
                            android:id="@+id/tvNowPlayingStop"
                            android:layout_width="32dp" android:layout_height="32dp"
                            android:text="✕" android:textColor="#8888AA"
                            android:textSize="16sp" android:gravity="center"
                            android:clickable="true" android:focusable="true"/>

                    </LinearLayout>

                    <!-- Radio volume wave -->
                    <is.dyino.ui.sounds.WaveView
                        android:id="@+id/radioVolumeWave"
                        android:layout_width="match_parent"
                        android:layout_height="36dp"
                        android:layout_marginLeft="14dp"
                        android:layout_marginRight="14dp"
                        android:layout_marginBottom="12dp"/>

                </LinearLayout>

            </FrameLayout>

            <!--
              Action row: Sleep Timer | Discover Stations
              Visible whenever radio OR sounds are playing.
            -->
            <LinearLayout
                android:id="@+id/actionButtonsRow"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="12dp"
                android:visibility="gone">

                <TextView
                    android:id="@+id/btnSleepTimer"
                    android:layout_width="0dp"
                    android:layout_height="38dp"
                    android:layout_weight="1"
                    android:text="Sleep Timer"
                    android:textSize="12sp"
                    android:textColor="#8888AA"
                    android:gravity="center"
                    android:clickable="true" android:focusable="true"/>

                <View
                    android:layout_width="8dp"
                    android:layout_height="38dp"/>

                <TextView
                    android:id="@+id/btnDiscoverStation"
                    android:layout_width="0dp"
                    android:layout_height="38dp"
                    android:layout_weight="1"
                    android:text="Discover"
                    android:textSize="12sp"
                    android:textColor="#8888AA"
                    android:gravity="center"
                    android:clickable="true" android:focusable="true"/>

            </LinearLayout>

            <!-- ACTIVE SOUNDS label -->
            <TextView
                android:id="@+id/tvNowPlayingSoundsLabel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="ACTIVE SOUNDS"
                android:textColor="#FFFFFF" android:textSize="11sp"
                android:letterSpacing="0.1" android:fontFamily="sans-serif-medium"
                android:paddingBottom="8dp"
                android:visibility="gone"/>

            <!-- Scrollable active sound chips -->
            <HorizontalScrollView
                android:id="@+id/nowPlayingSoundsScroll"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:scrollbars="none"
                android:overScrollMode="never"
                android:layout_marginBottom="8dp"
                android:visibility="gone">

                <LinearLayout
                    android:id="@+id/nowPlayingSoundsContainer"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"/>

            </HorizontalScrollView>

            <View
                android:id="@+id/dividerNowPlaying"
                android:layout_width="match_parent" android:layout_height="1dp"
                android:background="#22223A"
                android:visibility="gone"/>

            <!-- VISUALIZER section -->
            <TextView
                android:id="@+id/tvVisualizerLabel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="VISUALIZER"
                android:textColor="#FFFFFF" android:textSize="11sp"
                android:letterSpacing="0.1" android:fontFamily="sans-serif-medium"
                android:paddingTop="16dp" android:paddingBottom="8dp"
                android:visibility="gone"/>

            <is.dyino.ui.home.AudioVisualizerView
                android:id="@+id/audioVisualizer"
                android:layout_width="match_parent"
                android:layout_height="72dp"
                android:layout_marginBottom="16dp"
                android:visibility="gone"/>

            <!-- FAVOURITE RADIO -->
            <TextView
                android:id="@+id/tvFavRadioLabel"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="FAVOURITE RADIO"
                android:textColor="#FFFFFF" android:textSize="11sp"
                android:letterSpacing="0.1" android:fontFamily="sans-serif-medium"
                android:paddingTop="20dp" android:paddingBottom="10dp"
                android:visibility="gone"/>

            <LinearLayout
                android:id="@+id/favRadioContainer"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:layout_marginBottom="4dp"/>

            <!-- FAVOURITE SOUNDS -->
            <TextView
                android:id="@+id/tvFavSoundsLabel"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="FAVOURITE SOUNDS"
                android:textColor="#FFFFFF" android:textSize="11sp"
                android:letterSpacing="0.1" android:fontFamily="sans-serif-medium"
                android:paddingTop="16dp" android:paddingBottom="10dp"
                android:visibility="gone"/>

            <LinearLayout
                android:id="@+id/favSoundsContainer"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:layout_marginBottom="4dp"/>

            <View
                android:id="@+id/dividerFav"
                android:layout_width="match_parent" android:layout_height="1dp"
                android:background="#22223A"
                android:visibility="gone"/>

            <!-- RECENTLY PLAYED -->
            <TextView
                android:id="@+id/tvLastPlayedLabel"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="RECENTLY PLAYED"
                android:textColor="#FFFFFF" android:textSize="11sp"
                android:letterSpacing="0.1" android:fontFamily="sans-serif-medium"
                android:paddingTop="20dp" android:paddingBottom="10dp"
                android:visibility="gone"/>

            <LinearLayout
                android:id="@+id/lastPlayedContainer"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:layout_marginBottom="4dp"/>

            <View
                android:id="@+id/dividerLastPlayed"
                android:layout_width="match_parent" android:layout_height="1dp"
                android:background="#22223A"
                android:visibility="gone"/>

            <!-- Empty state -->
            <TextView
                android:id="@+id/tvEmpty"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="Nothing playing yet.\n\nTap a radio station or sound to begin.\nDouble-tap to add to Favourites."
                android:textColor="#44445A" android:textSize="13sp"
                android:lineSpacingExtra="4dp" android:paddingTop="48dp"
                android:gravity="center"/>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</LinearLayout>