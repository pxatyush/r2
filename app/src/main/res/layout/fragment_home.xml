<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/homeRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0D0D14">

    <!-- Header (no icon) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingLeft="16dp" android:paddingRight="16dp"
        android:paddingTop="20dp"  android:paddingBottom="12dp">

        <TextView
            android:id="@+id/tvHomePageTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Home"
            android:textColor="#FFFFFF"
            android:textSize="26sp"
            android:fontFamily="sans-serif-medium"/>

        <TextView
            android:id="@+id/tvHomePageSubtitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Your ambient space"
            android:textColor="#8888AA"
            android:textSize="13sp"
            android:paddingTop="2dp"/>

    </LinearLayout>

    <View android:layout_width="match_parent" android:layout_height="1dp"
        android:background="#22223A"/>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:overScrollMode="never">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingLeft="16dp" android:paddingRight="16dp"
            android:paddingBottom="24dp">

            <!-- NOW PLAYING label -->
            <TextView
                android:id="@+id/tvNowPlayingLabel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="NOW PLAYING"
                android:textColor="#FFFFFF" android:textSize="11sp"
                android:letterSpacing="0.1" android:fontFamily="sans-serif-medium"
                android:paddingTop="20dp" android:paddingBottom="10dp"
                android:visibility="gone"/>

            <!--
              Radio now-playing card.
              elevation + translationZ create the 3D raised effect.
              CardView is avoided to keep custom corner radius from code.
            -->
            <FrameLayout
                android:id="@+id/nowPlayingRadioCard"
                android:layout_width="match_parent"
                android:layout_height="80dp"
                android:layout_marginBottom="6dp"
                android:elevation="8dp"
                android:translationZ="4dp"
                android:clickable="true" android:focusable="true"
                android:visibility="gone">

                <!-- Wave visualiser behind content -->
                <is.dyino.ui.sounds.WaveView
                    android:id="@+id/radioWaveView"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:visibility="invisible"/>

                <!-- Main content -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingLeft="14dp" android:paddingRight="10dp">

                    <ImageView
                        android:id="@+id/ivStationIcon"
                        android:layout_width="40dp" android:layout_height="40dp"
                        android:src="@drawable/ic_note_vec"
                        android:scaleType="centerCrop"
                        android:layout_marginEnd="12dp"/>

                    <LinearLayout
                        android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical">

                        <TextView
                            android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:text="Radio" android:textColor="#8888AA" android:textSize="11sp"/>

                        <TextView
                            android:id="@+id/tvNowPlayingStation"
                            android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:textColor="#FFFFFF" android:textSize="15sp"
                            android:fontFamily="sans-serif-medium"
                            android:singleLine="true" android:ellipsize="end"/>

                        <TextView
                            android:id="@+id/tvBuffering"
                            android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:text="Buffering…" android:textColor="#6C63FF"
                            android:textSize="11sp" android:paddingTop="1dp"
                            android:visibility="gone"/>

                    </LinearLayout>

                    <!-- Sleep timer pill button -->
                    <TextView
                        android:id="@+id/btnSleepTimer"
                        android:layout_width="wrap_content"
                        android:layout_height="28dp"
                        android:text="Sleep"
                        android:textSize="11sp"
                        android:textColor="#8888AA"
                        android:gravity="center"
                        android:paddingLeft="10dp" android:paddingRight="10dp"
                        android:layout_marginEnd="6dp"
                        android:clickable="true" android:focusable="true"/>

                    <!-- Stop button -->
                    <TextView
                        android:id="@+id/tvNowPlayingStop"
                        android:layout_width="32dp" android:layout_height="32dp"
                        android:text="✕" android:textColor="#8888AA" android:textSize="16sp"
                        android:gravity="center"
                        android:clickable="true" android:focusable="true"/>

                </LinearLayout>
            </FrameLayout>

            <!-- Active sounds label -->
            <TextView
                android:id="@+id/tvNowPlayingSoundsLabel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="ACTIVE SOUNDS"
                android:textColor="#FFFFFF" android:textSize="11sp"
                android:letterSpacing="0.1" android:fontFamily="sans-serif-medium"
                android:paddingTop="10dp" android:paddingBottom="8dp"
                android:visibility="gone"/>

            <!-- Scrollable active-sound chips (each with WaveView + drag-vol) -->
            <HorizontalScrollView
                android:id="@+id/nowPlayingSoundsScroll"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:scrollbars="none"
                android:overScrollMode="never"
                android:layout_marginBottom="8dp"
                android:visibility="gone">

                <LinearLayout
                    android:id="@+id/nowPlayingSoundsContainer"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"/>

            </HorizontalScrollView>

            <View
                android:id="@+id/dividerNowPlaying"
                android:layout_width="match_parent" android:layout_height="1dp"
                android:background="#22223A"
                android:visibility="gone"/>

            <!-- FAVOURITE RADIO -->
            <TextView
                android:id="@+id/tvFavRadioLabel"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="FAVOURITE RADIO"
                android:textColor="#FFFFFF" android:textSize="11sp"
                android:letterSpacing="0.1" android:fontFamily="sans-serif-medium"
                android:paddingTop="20dp" android:paddingBottom="10dp"
                android:visibility="gone"/>

            <LinearLayout
                android:id="@+id/favRadioContainer"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:layout_marginBottom="4dp"/>

            <!-- FAVOURITE SOUNDS -->
            <TextView
                android:id="@+id/tvFavSoundsLabel"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="FAVOURITE SOUNDS"
                android:textColor="#FFFFFF" android:textSize="11sp"
                android:letterSpacing="0.1" android:fontFamily="sans-serif-medium"
                android:paddingTop="16dp" android:paddingBottom="10dp"
                android:visibility="gone"/>

            <LinearLayout
                android:id="@+id/favSoundsContainer"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:layout_marginBottom="4dp"/>

            <View
                android:id="@+id/dividerFav"
                android:layout_width="match_parent" android:layout_height="1dp"
                android:background="#22223A"
                android:visibility="gone"/>

            <!-- RECENTLY PLAYED -->
            <TextView
                android:id="@+id/tvLastPlayedLabel"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="RECENTLY PLAYED"
                android:textColor="#FFFFFF" android:textSize="11sp"
                android:letterSpacing="0.1" android:fontFamily="sans-serif-medium"
                android:paddingTop="20dp" android:paddingBottom="10dp"
                android:visibility="gone"/>

            <LinearLayout
                android:id="@+id/lastPlayedContainer"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:layout_marginBottom="4dp"/>

            <View
                android:id="@+id/dividerLastPlayed"
                android:layout_width="match_parent" android:layout_height="1dp"
                android:background="#22223A"
                android:visibility="gone"/>

            <!-- Empty state -->
            <TextView
                android:id="@+id/tvEmpty"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="Nothing playing yet.\n\nTap a radio station or sound to begin.\nDouble-tap to add to Favourites."
                android:textColor="#44445A" android:textSize="13sp"
                android:lineSpacingExtra="4dp" android:paddingTop="48dp"
                android:gravity="center"/>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</LinearLayout>
