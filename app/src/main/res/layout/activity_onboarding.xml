<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0D0D14"
    android:gravity="center_horizontal">

    <View android:layout_width="1dp" android:layout_height="0dp" android:layout_weight="1"/>

    <ImageView
        android:id="@+id/ivOnboardingLogo"
        android:layout_width="64dp"
        android:layout_height="64dp"
        android:src="@drawable/ic_note_vec"
        android:scaleType="fitCenter"
        android:alpha="0.9"/>

    <TextView
        android:id="@+id/tvOnboardingAppName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="dyino"
        android:textColor="#FFFFFF"
        android:textSize="40sp"
        android:fontFamily="sans-serif-light"
        android:letterSpacing="0.1"
        android:layout_marginTop="16dp"/>

    <TextView
        android:id="@+id/tvOnboardingTagline"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Ambient Radio &amp; Sounds"
        android:textColor="#8888AA"
        android:textSize="14sp"
        android:letterSpacing="0.05"
        android:layout_marginTop="6dp"/>

    <View
        android:id="@+id/viewOnboardingAccentBar"
        android:layout_width="32dp"
        android:layout_height="2dp"
        android:background="#6C63FF"
        android:layout_marginTop="28dp"
        android:layout_marginBottom="36dp"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingLeft="48dp"
        android:paddingRight="48dp">

        <LinearLayout
            android:id="@+id/tvOnboardingDot1" 
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="top" android:layout_marginBottom="16dp">
            <View 
                android:id="@+id/dotBullet1"
                android:layout_width="4dp" android:layout_height="4dp"
                android:background="#6C63FF"
                android:layout_marginTop="8dp" android:layout_marginRight="14dp"/>
            <TextView 
                android:id="@+id/tvOnboardingStep1"
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Tap a radio station to stream it"
                android:textColor="#CCCCCC" android:textSize="14sp" android:lineSpacingExtra="4dp"/>
        </LinearLayout>

        <LinearLayout 
            android:id="@+id/tvOnboardingDot2"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="top" android:layout_marginBottom="16dp">
            <View 
                android:id="@+id/dotBullet2"
                android:layout_width="4dp" android:layout_height="4dp"
                android:background="#6C63FF"
                android:layout_marginTop="8dp" android:layout_marginRight="14dp"/>
            <TextView 
                android:id="@+id/tvOnboardingStep2"
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Tap sound buttons to layer ambient sounds"
                android:textColor="#CCCCCC" android:textSize="14sp" android:lineSpacingExtra="4dp"/>
        </LinearLayout>

        <LinearLayout 
            android:id="@+id/tvOnboardingDot3"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="top" android:layout_marginBottom="16dp">
            <View 
                android:id="@+id/dotBullet3"
                android:layout_width="4dp" android:layout_height="4dp"
                android:background="#6C63FF"
                android:layout_marginTop="8dp" android:layout_marginRight="14dp"/>
            <TextView 
                android:id="@+id/tvOnboardingStep3"
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Long press a sound to adjust its volume"
                android:textColor="#CCCCCC" android:textSize="14sp" android:lineSpacingExtra="4dp"/>
        </LinearLayout>

        <LinearLayout 
            android:id="@+id/tvOnboardingDot4"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="top">
            <View 
                android:id="@+id/dotBullet4"
                android:layout_width="4dp" android:layout_height="4dp"
                android:background="#6C63FF"
                android:layout_marginTop="8dp" android:layout_marginRight="14dp"/>
            <TextView 
                android:id="@+id/tvOnboardingStep4"
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Double tap any station or sound to favourite it"
                android:textColor="#CCCCCC" android:textSize="14sp" android:lineSpacingExtra="4dp"/>
        </LinearLayout>

    </LinearLayout>

    <View android:layout_width="1dp" android:layout_height="0dp" android:layout_weight="1"/>

    <TextView
        android:id="@+id/btnGetStarted"
        android:layout_width="220dp"
        android:layout_height="52dp"
        android:text="Get Started"
        android:textColor="#FFFFFF"
        android:textSize="15sp"
        android:fontFamily="sans-serif-medium"
        android:gravity="center"
        android:background="@drawable/bg_stop_all_btn"
        android:clickable="true"
        android:focusable="true"/>

    <TextView
        android:id="@+id/tvOnboardingBy"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="by pxatyush"
        android:textColor="#33445A"
        android:textSize="12sp"
        android:layout_marginTop="20dp"
        android:layout_marginBottom="32dp"/>

</LinearLayout>
