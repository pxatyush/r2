<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_dark">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Settings"
        android:textColor="@color/text_primary"
        android:textSize="22sp"
        android:fontFamily="sans-serif-medium"
        android:paddingLeft="16dp"
        android:paddingRight="16dp"
        android:paddingTop="20dp"
        android:paddingBottom="12dp" />

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:overScrollMode="never">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingLeft="12dp"
            android:paddingRight="12dp"
            android:paddingBottom="32dp">

            <!-- Toggles card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_card"
                android:padding="4dp"
                android:layout_marginBottom="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingLeft="16dp"
                    android:paddingRight="12dp">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="HAPTIC FEEDBACK"
                        android:textColor="@color/text_primary"
                        android:textSize="12sp"
                        android:letterSpacing="0.1"
                        android:fontFamily="sans-serif-medium" />
                    <androidx.appcompat.widget.SwitchCompat
                        android:id="@+id/switchHaptic"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:checked="true" />
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp"
                    android:background="@color/divider"
                    android:layout_marginLeft="16dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingLeft="16dp"
                    android:paddingRight="12dp">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="BUTTON SOUND EFFECTS"
                        android:textColor="@color/text_primary"
                        android:textSize="12sp"
                        android:letterSpacing="0.1"
                        android:fontFamily="sans-serif-medium" />
                    <androidx.appcompat.widget.SwitchCompat
                        android:id="@+id/switchButtonSound"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:checked="true" />
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp"
                    android:background="@color/divider"
                    android:layout_marginLeft="16dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingLeft="16dp"
                    android:paddingRight="12dp">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="DARK MODE"
                        android:textColor="@color/text_primary"
                        android:textSize="12sp"
                        android:letterSpacing="0.1"
                        android:fontFamily="sans-serif-medium" />
                    <androidx.appcompat.widget.SwitchCompat
                        android:id="@+id/switchDarkMode"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:checked="true" />
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp"
                    android:background="@color/divider"
                    android:layout_marginLeft="16dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingLeft="16dp"
                    android:paddingRight="12dp">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="SHOW GIF VISUALIZER"
                        android:textColor="@color/text_primary"
                        android:textSize="12sp"
                        android:letterSpacing="0.1"
                        android:fontFamily="sans-serif-medium" />
                    <androidx.appcompat.widget.SwitchCompat
                        android:id="@+id/switchGif"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:checked="true" />
                </LinearLayout>

            </LinearLayout>

            <!-- GIF Search Tag -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_card"
                android:padding="16dp"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="GIF SEARCH TAG"
                    android:textColor="@color/text_secondary"
                    android:textSize="11sp"
                    android:letterSpacing="0.1"
                    android:paddingBottom="8dp" />

                <EditText
                    android:id="@+id/etGifTag"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:text="nature"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp"
                    android:background="@drawable/bg_radio_item"
                    android:paddingLeft="12dp"
                    android:paddingRight="12dp"
                    android:hint="e.g. nature, space, water"
                    android:hintTextColor="@color/text_secondary"
                    android:imeOptions="actionDone"
                    android:inputType="text" />

            </LinearLayout>

            <!-- Accent Color -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_card"
                android:padding="16dp"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="ACCENT COLOR"
                    android:textColor="@color/text_secondary"
                    android:textSize="11sp"
                    android:letterSpacing="0.1"
                    android:paddingBottom="12dp" />

                <LinearLayout
                    android:id="@+id/accentColorRow"
                    android:layout_width="match_parent"
                    android:layout_height="40dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical" />

            </LinearLayout>

            <!-- Background Color -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_card"
                android:padding="16dp"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="BACKGROUND COLOR"
                    android:textColor="@color/text_secondary"
                    android:textSize="11sp"
                    android:letterSpacing="0.1"
                    android:paddingBottom="12dp" />

                <LinearLayout
                    android:id="@+id/bgColorRow"
                    android:layout_width="match_parent"
                    android:layout_height="40dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical" />

            </LinearLayout>

            <!-- Text Color -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_card"
                android:padding="16dp"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="TEXT COLOR"
                    android:textColor="@color/text_secondary"
                    android:textSize="11sp"
                    android:letterSpacing="0.1"
                    android:paddingBottom="12dp" />

                <LinearLayout
                    android:id="@+id/textColorRow"
                    android:layout_width="match_parent"
                    android:layout_height="40dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical" />

            </LinearLayout>

            <!-- Font Style -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_card"
                android:padding="16dp"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="FONT STYLE"
                    android:textColor="@color/text_secondary"
                    android:textSize="11sp"
                    android:letterSpacing="0.1"
                    android:paddingBottom="12dp" />

                <LinearLayout
                    android:id="@+id/fontStyleRow"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical" />

            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="dyino  v1.0"
                android:textColor="@color/text_secondary"
                android:textSize="11sp"
                android:gravity="center"
                android:paddingTop="8dp" />

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

</LinearLayout>
