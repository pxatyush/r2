<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Settings"
            android:textColor="@color/text_primary"
            android:textSize="22sp"
            android:textStyle="bold"
            android:layout_marginBottom="16dp"
            android:layout_marginTop="16dp"/>

        <!-- Toggles Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card"
            android:padding="4dp"
            android:layout_marginBottom="16dp">

            <!-- Haptic Feedback -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingHorizontal="16dp">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="HAPTIC FEEDBACK"
                    android:textColor="@color/text_primary"
                    android:textSize="11sp"
                    android:letterSpacing="0.1"
                    android:fontFamily="sans-serif-medium"/>
                <Switch
                    android:id="@+id/sw_haptic"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checked="true"/>
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/divider" android:marginHorizontal="16dp"/>

            <!-- Button Sound -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingHorizontal="16dp">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="BUTTON SOUND EFFECTS"
                    android:textColor="@color/text_primary"
                    android:textSize="11sp"
                    android:letterSpacing="0.1"
                    android:fontFamily="sans-serif-medium"/>
                <Switch
                    android:id="@+id/sw_button_sound"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checked="true"/>
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/divider" android:marginHorizontal="16dp"/>

            <!-- Dark Mode -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingHorizontal="16dp">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="DARK MODE"
                    android:textColor="@color/text_primary"
                    android:textSize="11sp"
                    android:letterSpacing="0.1"
                    android:fontFamily="sans-serif-medium"/>
                <Switch
                    android:id="@+id/sw_dark_mode"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checked="true"/>
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/divider" android:marginHorizontal="16dp"/>

            <!-- Show GIF Visualizer -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingHorizontal="16dp">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="SHOW GIF VISUALIZER"
                    android:textColor="@color/text_primary"
                    android:textSize="11sp"
                    android:letterSpacing="0.1"
                    android:fontFamily="sans-serif-medium"/>
                <Switch
                    android:id="@+id/sw_show_gif"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checked="true"/>
            </LinearLayout>

        </LinearLayout>

        <!-- GIF Search Tag -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card"
            android:padding="16dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="GIF SEARCH TAG"
                android:textColor="@color/text_secondary"
                android:textSize="10sp"
                android:letterSpacing="0.12"
                android:layout_marginBottom="8dp"/>

            <EditText
                android:id="@+id/et_gif_tag"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:hint="e.g. nature, space, abstract"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_secondary"
                android:background="@drawable/bg_radio_item"
                android:paddingHorizontal="12dp"
                android:textSize="14sp"
                android:inputType="text"
                android:text="nature"/>

        </LinearLayout>

        <!-- Accent Color -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card"
            android:padding="16dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ACCENT COLOR"
                android:textColor="@color/text_secondary"
                android:textSize="10sp"
                android:letterSpacing="0.12"
                android:layout_marginBottom="12dp"/>

            <LinearLayout
                android:id="@+id/accent_colors"
                android:layout_width="match_parent"
                android:layout_height="36dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"/>

        </LinearLayout>

        <!-- Background Color -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card"
            android:padding="16dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="BACKGROUND COLOR"
                android:textColor="@color/text_secondary"
                android:textSize="10sp"
                android:letterSpacing="0.12"
                android:layout_marginBottom="12dp"/>

            <LinearLayout
                android:id="@+id/bg_colors"
                android:layout_width="match_parent"
                android:layout_height="36dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"/>

        </LinearLayout>

        <!-- Text Color -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card"
            android:padding="16dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="TEXT COLOR"
                android:textColor="@color/text_secondary"
                android:textSize="10sp"
                android:letterSpacing="0.12"
                android:layout_marginBottom="12dp"/>

            <LinearLayout
                android:id="@+id/text_colors"
                android:layout_width="match_parent"
                android:layout_height="36dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"/>

        </LinearLayout>

        <!-- Font Style -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card"
            android:padding="16dp"
            android:layout_marginBottom="32dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="FONT STYLE"
                android:textColor="@color/text_secondary"
                android:textSize="10sp"
                android:letterSpacing="0.12"
                android:layout_marginBottom="12dp"/>

            <Spinner
                android:id="@+id/spinner_font"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:background="@drawable/bg_radio_item"
                android:paddingHorizontal="12dp"
                android:popupBackground="@color/bg_card2"/>

        </LinearLayout>

    </LinearLayout>
</ScrollView>
