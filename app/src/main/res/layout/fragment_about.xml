<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0D0D14">

    <LinearLayout 
        android:layout_width="match_parent" 
        android:layout_height="56dp"
        android:orientation="horizontal" 
        android:gravity="center_vertical"
        android:paddingStart="8dp"
        android:paddingEnd="16dp">
        
        <ImageButton 
            android:id="@+id/btnAboutBack"
            android:layout_width="48dp" 
            android:layout_height="48dp"
            android:src="@android:drawable/ic_menu_close_clear_cancel"
            android:background="@null" 
            android:contentDescription="Back"/>
            
        <TextView 
            android:layout_width="wrap_content" 
            android:layout_height="wrap_content"
            android:text="About" 
            android:textColor="#FFFFFF" 
            android:textSize="20sp"
            android:textStyle="bold"
            android:fontFamily="sans-serif"
            android:layout_marginStart="8dp"/>
    </LinearLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:overScrollMode="never">

        <LinearLayout 
            android:layout_width="match_parent" 
            android:layout_height="wrap_content"
            android:orientation="vertical" 
            android:gravity="center_horizontal"
            android:paddingStart="32dp" 
            android:paddingEnd="32dp" 
            android:paddingBottom="48dp">

            <ImageView 
                android:layout_width="80dp" 
                android:layout_height="80dp"
                android:src="@mipmap/ic_launcher" 
                android:layout_marginTop="32dp"
                android:background="@drawable/bg_card" 
                android:padding="16dp"
                android:layout_gravity="center_horizontal"/>

            <TextView 
                android:layout_width="wrap_content" 
                android:layout_height="wrap_content"
                android:text="dyino" 
                android:textColor="#FFFFFF" 
                android:textSize="32sp"
                android:textStyle="bold"
                android:letterSpacing="-0.02"
                android:fontFamily="sans-serif" 
                android:layout_marginTop="16dp"/>

            <TextView 
                android:layout_width="wrap_content" 
                android:layout_height="wrap_content"
                android:text="Ambient Radio &amp; Sounds" 
                android:textColor="#8888AA"
                android:textSize="14sp" 
                android:fontFamily="sans-serif-medium"
                android:layout_marginTop="4dp"/>

            <TextView 
                android:layout_width="wrap_content" 
                android:layout_height="wrap_content"
                android:text="v1.0" 
                android:textColor="#44445A"
                android:textSize="12sp" 
                android:textStyle="bold"
                android:letterSpacing="0.05"
                android:layout_marginTop="8dp"/>

            <View 
                android:layout_width="48dp" 
                android:layout_height="2dp"
                android:background="#22223A" 
                android:layout_marginTop="32dp"
                android:layout_marginBottom="32dp"/>

            <TextView 
                android:layout_width="wrap_content" 
                android:layout_height="wrap_content"
                android:text="pxatyush" 
                android:textColor="#6C63FF" 
                android:textSize="22sp"
                android:textStyle="bold"
                android:letterSpacing="-0.01"
                android:fontFamily="sans-serif"/>

            <LinearLayout 
                android:layout_width="match_parent" 
                android:layout_height="wrap_content"
                android:orientation="vertical" 
                android:paddingTop="20dp">

                <TextView android:id="@+id/linkGithub" 
                    android:layout_width="match_parent"
                    android:layout_height="52dp" 
                    android:gravity="center"
                    android:text="github.com/pxatyush"
                    android:textColor="#FFFFFF" 
                    android:textSize="15sp"
                    android:fontFamily="sans-serif-medium"
                    android:background="@drawable/bg_card" 
                    android:layout_marginBottom="8dp" 
                    android:clickable="true" 
                    android:focusable="true"/>

                <TextView android:id="@+id/linkInstagram" 
                    android:layout_width="match_parent"
                    android:layout_height="52dp" 
                    android:gravity="center"
                    android:text="instagram.com/pxatyush"
                    android:textColor="#FFFFFF" 
                    android:textSize="15sp"
                    android:fontFamily="sans-serif-medium"
                    android:background="@drawable/bg_card" 
                    android:layout_marginBottom="8dp" 
                    android:clickable="true" 
                    android:focusable="true"/>

                <TextView android:id="@+id/linkTelegram" 
                    android:layout_width="match_parent"
                    android:layout_height="52dp" 
                    android:gravity="center"
                    android:text="t.me/pxatyush"
                    android:textColor="#FFFFFF" 
                    android:textSize="15sp"
                    android:fontFamily="sans-serif-medium"
                    android:background="@drawable/bg_card" 
                    android:layout_marginBottom="8dp" 
                    android:clickable="true" 
                    android:focusable="true"/>

                <TextView android:id="@+id/linkLinkedin" 
                    android:layout_width="match_parent"
                    android:layout_height="52dp" 
                    android:gravity="center"
                    android:text="linkedin.com/in/pxatyush"
                    android:textColor="#FFFFFF" 
                    android:textSize="15sp"
                    android:fontFamily="sans-serif-medium"
                    android:background="@drawable/bg_card" 
                    android:layout_marginBottom="8dp" 
                    android:clickable="true" 
                    android:focusable="true"/>

                <TextView android:id="@+id/linkTwitter" 
                    android:layout_width="match_parent"
                    android:layout_height="52dp" 
                    android:gravity="center"
                    android:text="twitter.com/pxatyush"
                    android:textColor="#FFFFFF" 
                    android:textSize="15sp"
                    android:fontFamily="sans-serif-medium"
                    android:background="@drawable/bg_card" 
                    android:clickable="true" 
                    android:focusable="true"/>

            </LinearLayout>

            <View 
                android:layout_width="match_parent" 
                android:layout_height="1dp"
                android:background="#22223A" 
                android:layout_marginTop="32dp"
                android:layout_marginBottom="24dp"/>

            <TextView 
                android:layout_width="match_parent" 
                android:layout_height="wrap_content"
                android:text="OPEN SOURCE" 
                android:textColor="#FFFFFF" 
                android:textSize="13sp"
                android:textStyle="bold"
                android:letterSpacing="0.05"
                android:fontFamily="sans-serif-medium" 
                android:gravity="center"
                android:paddingBottom="8dp"/>

            <TextView 
                android:layout_width="match_parent" 
                android:layout_height="wrap_content"
                android:text="android-gif-drawable  ·  OkHttp\nGlide  ·  Gson"
                android:lineSpacingExtra="6dp"
                android:textColor="#44445A" 
                android:textSize="12sp" 
                android:gravity="center"/>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</LinearLayout>
