<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/soundsRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_dark">

    <FrameLayout
        android:id="@+id/gifContainerSounds"
        android:layout_width="match_parent"
        android:layout_height="220dp"
        android:background="@drawable/bg_gif_container"
        android:visibility="visible">

        <pl.droidsonroids.gif.GifImageView
            android:id="@+id/gifViewSounds"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop" />

        <View
            android:layout_width="match_parent"
            android:layout_height="80dp"
            android:layout_gravity="bottom"
            android:background="@drawable/gradient_bottom_fade" />

        <ProgressBar
            android:id="@+id/gifLoadingSounds"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_gravity="center"
            android:indeterminateTint="#6C63FF"
            android:visibility="visible" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom"
            android:orientation="horizontal"
            android:gravity="end"
            android:paddingRight="14dp"
            android:paddingBottom="10dp">

            <TextView
                android:id="@+id/btnStopAll"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="&#9646;  Stop All"
                android:textColor="@color/white"
                android:textSize="12sp"
                android:gravity="center"
                android:paddingLeft="14dp"
                android:paddingRight="14dp"
                android:background="@drawable/bg_stop_all_btn"
                android:clickable="true"
                android:focusable="true" />

        </LinearLayout>

    </FrameLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:overScrollMode="never">

        <LinearLayout
            android:id="@+id/soundsCategoriesContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="24dp" />

    </androidx.core.widget.NestedScrollView>

</LinearLayout>
