<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/radioRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0D0D14">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingLeft="16dp"
        android:paddingRight="16dp"
        android:paddingTop="20dp"
        android:paddingBottom="12dp">

        <ImageView
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/ic_note"
            android:scaleType="fitCenter"
            android:alpha="0.65"
            android:layout_gravity="center_horizontal"/>

        <TextView
            android:id="@+id/tvSectionLabel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Radio"
            android:textColor="#FFFFFF"
            android:textSize="26sp"
            android:fontFamily="sans-serif-medium"
            android:paddingTop="8dp"/>

        <TextView
            android:id="@+id/tvNowPlayingTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Select a station"
            android:textColor="#8888AA"
            android:textSize="13sp"
            android:paddingTop="2dp"
            android:singleLine="true"
            android:ellipsize="marquee"
            android:marqueeRepeatLimit="marquee_forever"/>

        <!-- Controls row: play/pause | fav (right) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingTop="10dp">

            <!-- Play/Pause -->
            <ImageButton
                android:id="@+id/btnPlayPause"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:src="@drawable/ic_play"
                android:background="@null"
                android:scaleType="fitCenter"
                android:contentDescription="Play/Pause"/>

            <!-- Fav button — smaller, right next to play -->
            <ImageButton
                android:id="@+id/btnFavourite"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@drawable/ic_fav_off"
                android:background="@null"
                android:scaleType="fitCenter"
                android:layout_marginLeft="6dp"
                android:contentDescription="Favourite"/>

            <!-- Spacer -->
            <View android:layout_width="0dp" android:layout_height="1dp" android:layout_weight="1"/>

            <!-- Volume toggle hint -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="hold ▶ for volume"
                android:textColor="#44445A"
                android:textSize="10sp"/>

        </LinearLayout>

        <!-- Volume slider (hidden by default, shown on long press of play) -->
        <LinearLayout
            android:id="@+id/volumeSliderContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingTop="6dp"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Vol"
                android:textColor="#8888AA"
                android:textSize="11sp"/>

            <SeekBar
                android:id="@+id/radioVolumeSeek"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginLeft="10dp"
                android:max="100"
                android:progress="80"/>

        </LinearLayout>

    </LinearLayout>

    <View android:layout_width="match_parent" android:layout_height="1dp"
        android:background="#22223A"/>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/radioRecycler"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingLeft="12dp"
        android:paddingRight="12dp"
        android:paddingBottom="16dp"
        android:clipToPadding="false"
        android:overScrollMode="never"/>

</LinearLayout>
