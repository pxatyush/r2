<?xml version="1.0" encoding="utf-8"?>
<!--
  Root FrameLayout lets MainActivity dynamically place navBar at start/end/bottom.
  contentArea fills everything; its margins are adjusted in code.
-->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/rootLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0D0D14">

    <!-- Content: fragments live here; margins adjusted by MainActivity -->
    <FrameLayout
        android:id="@+id/contentArea"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <FrameLayout android:id="@+id/fragmentHome"
            android:layout_width="match_parent" android:layout_height="match_parent"
            android:visibility="visible"/>
        <FrameLayout android:id="@+id/fragmentRadio"
            android:layout_width="match_parent" android:layout_height="match_parent"
            android:visibility="gone"/>
        <FrameLayout android:id="@+id/fragmentSounds"
            android:layout_width="match_parent" android:layout_height="match_parent"
            android:visibility="gone"/>
        <FrameLayout android:id="@+id/fragmentSettings"
            android:layout_width="match_parent" android:layout_height="match_parent"
            android:visibility="gone"/>

    </FrameLayout>

    <!--
      Nav bar.  Layout_gravity, dimensions and orientation are
      overwritten in MainActivity.applyNavPosition().

      Default: left vertical bar.
      Bottom: horizontal bar, items weighted equally, labels not rotated.
    -->
    <LinearLayout
        android:id="@+id/navBar"
        android:layout_width="56dp"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="bottom|center_horizontal"
        android:paddingBottom="28dp"
        android:background="#0D0D14"
        android:layout_gravity="start">

        <View android:layout_width="1dp" android:layout_height="0dp" android:layout_weight="1"/>

        <!-- Settings — top when vertical (farthest from thumb), rightmost when bottom -->
        <FrameLayout android:id="@+id/navSettings"
            android:layout_width="56dp" android:layout_height="64dp"
            android:clickable="true" android:focusable="true">
            <TextView android:id="@+id/navSettingsText"
                android:layout_width="match_parent" android:layout_height="match_parent"
                android:text="Settings" android:textSize="11sp" android:letterSpacing="0.04"
                android:textColor="#44445A" android:gravity="center"
                android:rotation="-90" android:fontFamily="sans-serif-medium"/>
        </FrameLayout>

        <FrameLayout android:id="@+id/navSounds"
            android:layout_width="56dp" android:layout_height="64dp"
            android:clickable="true" android:focusable="true">
            <TextView android:id="@+id/navSoundsText"
                android:layout_width="match_parent" android:layout_height="match_parent"
                android:text="Sounds" android:textSize="11sp" android:letterSpacing="0.04"
                android:textColor="#44445A" android:gravity="center"
                android:rotation="-90" android:fontFamily="sans-serif-medium"/>
        </FrameLayout>

        <FrameLayout android:id="@+id/navRadio"
            android:layout_width="56dp" android:layout_height="64dp"
            android:clickable="true" android:focusable="true">
            <TextView android:id="@+id/navRadioText"
                android:layout_width="match_parent" android:layout_height="match_parent"
                android:text="Radio" android:textSize="11sp" android:letterSpacing="0.04"
                android:textColor="#44445A" android:gravity="center"
                android:rotation="-90" android:fontFamily="sans-serif-medium"/>
        </FrameLayout>

        <!-- Home — bottom (closest to thumb), leftmost when bottom -->
        <FrameLayout android:id="@+id/navHome"
            android:layout_width="56dp" android:layout_height="64dp"
            android:clickable="true" android:focusable="true">
            <TextView android:id="@+id/navHomeText"
                android:layout_width="match_parent" android:layout_height="match_parent"
                android:text="Home" android:textSize="11sp" android:letterSpacing="0.04"
                android:textColor="#FFFFFF" android:gravity="center"
                android:rotation="-90" android:fontFamily="sans-serif-medium"/>
        </FrameLayout>

    </LinearLayout>

</FrameLayout>
