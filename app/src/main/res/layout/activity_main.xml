<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/rootLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="horizontal"
    android:background="@color/bg_dark">

    <!-- Left vertical nav bar -->
    <LinearLayout
        android:id="@+id/navBar"
        android:layout_width="64dp"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center_vertical"
        android:paddingTop="24dp"
        android:paddingBottom="24dp"
        android:background="@color/bg_dark">

        <!-- Decorative sparkle -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="&#10022;"
            android:textSize="14sp"
            android:textColor="#22446688"
            android:gravity="center"
            android:paddingBottom="24dp" />

        <!-- Radio nav item -->
        <FrameLayout
            android:id="@+id/navRadio"
            android:layout_width="match_parent"
            android:layout_height="80dp"
            android:clickable="true"
            android:focusable="true">
            <TextView
                android:id="@+id/navRadioText"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:text="Radio"
                android:textSize="12sp"
                android:letterSpacing="0.06"
                android:textColor="@color/nav_selected"
                android:gravity="center"
                android:rotation="-90"
                android:fontFamily="sans-serif-medium" />
        </FrameLayout>

        <!-- Sounds nav item -->
        <FrameLayout
            android:id="@+id/navSounds"
            android:layout_width="match_parent"
            android:layout_height="80dp"
            android:clickable="true"
            android:focusable="true">
            <TextView
                android:id="@+id/navSoundsText"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:text="Sounds"
                android:textSize="12sp"
                android:letterSpacing="0.06"
                android:textColor="@color/nav_unselected"
                android:gravity="center"
                android:rotation="-90"
                android:fontFamily="sans-serif-medium" />
        </FrameLayout>

        <!-- Settings nav item -->
        <FrameLayout
            android:id="@+id/navSettings"
            android:layout_width="match_parent"
            android:layout_height="80dp"
            android:clickable="true"
            android:focusable="true">
            <TextView
                android:id="@+id/navSettingsText"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:text="Settings"
                android:textSize="12sp"
                android:letterSpacing="0.06"
                android:textColor="@color/nav_unselected"
                android:gravity="center"
                android:rotation="-90"
                android:fontFamily="sans-serif-medium" />
        </FrameLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="&#183;"
            android:textSize="18sp"
            android:textColor="#22446688"
            android:gravity="center"
            android:paddingBottom="8dp" />

    </LinearLayout>

    <!-- Thin divider -->
    <View
        android:layout_width="1dp"
        android:layout_height="match_parent"
        android:background="@color/divider" />

    <!-- Main content area - stacked fragments -->
    <FrameLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1">

        <FrameLayout
            android:id="@+id/fragmentRadio"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="visible" />

        <FrameLayout
            android:id="@+id/fragmentSounds"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone" />

        <FrameLayout
            android:id="@+id/fragmentSettings"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone" />

    </FrameLayout>

</LinearLayout>
