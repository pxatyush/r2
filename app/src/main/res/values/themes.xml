<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.Dyino" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/accent_default</item>
        <item name="colorPrimaryVariant">@color/bg_card</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSurface">@color/bg_dark</item>
        <item name="android:colorBackground">@color/bg_dark</item>
        <item name="android:windowBackground">@color/bg_dark</item>
        <item name="android:statusBarColor">@color/bg_dark</item>
        <item name="android:navigationBarColor">@color/bg_dark</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>

    <style name="NavText" parent="Widget.AppCompat.TextView">
        <item name="android:textSize">11sp</item>
        <item name="android:letterSpacing">0.08</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <style name="SoundButton">
        <item name="android:background">@drawable/bg_sound_button</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">14sp</item>
        <item name="android:padding">12dp</item>
        <item name="android:gravity">center</item>
    </style>
</resources>
